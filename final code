import speech_recognition
import pyttsx3
import os
import webbrowser
from datetime import datetime
import requests
import psutil
import pyautogui
import time
print("welcome to hanu, your personal assistant. I am here to help you with various tasks. Just say a command and I will do my best to assist you. If you want to ask me anything, just say 'tell me' followed by your question. Let's get started!")
history = []
voice_recognizer = speech_recognition.Recognizer()
def speak(text):
    try:
        speaking_engine = pyttsx3.init()
        speaking_engine.say(text)
        speaking_engine.runAndWait()
    except Exception as e:
        print("TTS Error:", e)
def ai_chat(question):
    global history
    history.append(f"User: {question}")
    # Keep only the last 15 messages
    if len(history) > 15:
        history = history[-15:]
    conversation = "\n".join(history)
    prompt = f"""
You are Hanu, a personal AI assistant.
Rules:
- reply in english if coudn't understand the language of the user.
- Understand Hindi, English and Hinglish.
- Reply in the english.
- Keep replies short because they will be spoken.
- Be friendly and helpful.
- Remember the previous conversation.
Conversation:
{conversation}
Assistant:
"""
    try:
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={
                "model": "llama3.2",
                "prompt": prompt,
                "stream": False
            },
            timeout=15
        )
        answer = response.json()["response"].strip()
        print("\nAI:" + answer)
        speak(answer)
        # Remember the assistant's reply in the conversation history
        history.append(f"Assistant: {answer}")
    except Exception as e:
        print("AI Error:", e)
        speak("Sorry, I am having trouble connecting to my local brain.")
while True:
    with speech_recognition.Microphone() as microphone:
        print("Sleeping (say 'junior [command]')...")
        voice_recognizer.adjust_for_ambient_noise(
            microphone,
            duration=0.5
        )
        try:
            recorded_audio = voice_recognizer.listen(
                microphone,
                timeout=10,
                phrase_time_limit=10
            )
        except speech_recognition.WaitTimeoutError:
            continue
        
    try:
        spoken_text = voice_recognizer.recognize_google(recorded_audio)
        
        # Check if the trigger word "junior" is present
        lower_text = spoken_text.lower()
        if "junior" not in lower_text:
            continue
            
        # Extract the command (the part after the word "junior")
        idx = lower_text.find("junior")
        command_text = spoken_text[idx + len("junior"):].strip()
        
        if not command_text:
            speak("Yes? Please say a command after junior.")
            continue
            
        spoken_text = command_text
        print(f"You said: {spoken_text}")
        if spoken_text.lower() == "open notepad":
            speak("opening notepad")
            os.startfile("notepad.exe")
        elif spoken_text.lower() == "open calculator":
            speak("opening calculator")
            os.startfile("calc.exe")
        elif spoken_text.lower() == "open chrome":
            speak("opening chrome") 
            # Fixed: removed nested quotes around path
            os.startfile(r"C:\Program Files\Google\Chrome\Application\chrome.exe")
        elif spoken_text.lower() == "open microsoft edge":
            speak("opening edge")
            # Fixed: removed nested quotes around path
            os.startfile(r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe")
        elif spoken_text.lower() == "open whatsapp":
            speak("opening whatsapp")
            webbrowser.open("https://web.whatsapp.com/")
            
        elif spoken_text.lower() == "open brave":
            speak("opening brave")
            # Fixed: removed nested quotes around path
            os.startfile(r"C:\Users\acer\AppData\Local\BraveSoftware\Brave-Browser\Application\brave.exe")
        elif spoken_text.lower() == "open youtube":
            speak("opening youtube")
            webbrowser.open("https://www.youtube.com/")
        elif spoken_text.lower() == "open linkedin":    
            speak("opening linkedin")
            webbrowser.open("https://www.linkedin.com/feed/")
        elif "what is the time" in spoken_text.lower():
            current_time = datetime.now()
            time_string = current_time.strftime("%I:%M %p")
            full_sentence = "The current time is " + time_string
            print(full_sentence)
            speak(full_sentence)
        elif "what is today's date" in spoken_text.lower():
            current_date = datetime.now()
            date_string = current_date.strftime("%d %B %Y")
            full_sentence = "Today's date is " + date_string
            print(full_sentence)
            speak(full_sentence)
        elif spoken_text.lower() == "open my card":
            speak("opening ECHS")
            webbrowser.open("https://echs.sourceinfosys.com/")
        elif spoken_text.lower() == "open my email":
            speak("opening email")
            webbrowser.open("https://mail.google.com/mail/u/0/#inbox")
        elif spoken_text.lower() == "hello":
            speak("Hello, I am hanu. My formal name is Hirdyanshu Singh Sisodiya. How can I assist you?") 
        elif spoken_text.lower() == "goodbye":
            speak("Goodbye! Have a great day!")
            break
        elif spoken_text.lower() == "what is the weather":
            try:
                url = "https://wttr.in/?format=%t"
                response = requests.get(url, timeout=5)
                temperature = response.text.strip()
                weather_message = "Current temperature is " + temperature
                print(weather_message)
                speak(weather_message)
            except Exception as e:
                print("Weather Error:", e)
                speak("I could not get the weather right now.")
        elif spoken_text.lower() == "battery percentage":
            battery = psutil.sensors_battery() 
            if battery is not None:
                battery_percentage = battery.percent
                battery_message = f"Your battery is at {battery_percentage} percent."
            else:
                battery_message = "Battery status is not available."
            print(battery_message)
            speak(battery_message)
 
        elif spoken_text.lower() == "take screenshot":
            screenshot = pyautogui.screenshot()
            screenshot.save("screenshot.png")
            print("Screenshot taken and saved as screenshot.png")
            speak("Screenshot taken and saved as screenshot.png")
        
        elif "volume increase" in spoken_text.lower():
            for i in range(5):
                pyautogui.press("volumeup")
            print("Volume increased")
            speak("Volume increased")
        elif "volume decrease" in spoken_text.lower():
            for i in range(5):
                pyautogui.press("volumedown")
            print("Volume decreased")
            speak("Volume decreased")
        elif "mute" in spoken_text.lower():
            pyautogui.press("volumemute")
            print("Volume muted")
            speak("Volume muted")
        elif "shutdown computer" in spoken_text.lower():
            speak("Shutting down computer")
            # Fixed: os.system instead of os.startfile for shell command execution
            os.system("shutdown /s /t 10")
        elif "restart computer" in spoken_text.lower():
            speak("Restarting computer")
            # Fixed: os.system instead of os.startfile for shell command execution
            os.system("shutdown /r /t 10")
        elif "cancel shutdown" in spoken_text.lower():
            # Fixed: os.system instead of os.startfile for shell command execution
            os.system("shutdown /a")
            speak("Shutdown cancelled")
        elif "search for" in spoken_text.lower():
            query = spoken_text.lower().replace("search for", "").strip()
            webbrowser.open(f"https://www.google.com/search?q={query}")
            print(f"Searching for {query}")
            speak(f"Searching for {query}")
            time.sleep(1)
        elif "youtube" in spoken_text.lower():
            query = spoken_text.lower().replace("youtube", "").strip()
            webbrowser.open(f"https://www.youtube.com/results?search_query={query}")
            print(f"Searching YouTube for {query}")
            speak(f"Searching YouTube for {query}")
        elif spoken_text.lower() == "exit":
            speak("Goodbye! Have a great day! istemal karne ke liye shukriya")
            break
        else:
            # Fixed: pass spoken_text instead of question (which was undefined).
            # Also clean off 'tell me' trigger if present.
            clean_question = spoken_text
            if clean_question.lower().startswith("tell me"):
                clean_question = clean_question[7:].strip()
            ai_chat(clean_question)
    except speech_recognition.UnknownValueError:
        pass
    except Exception as e:
        print("Error:", e)
