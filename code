print("welcome to hanu, your personal assistant. I am here to help you with various tasks. Just say a command and I will do my best to assist you. If you want to ask me anything, just say 'tell me' followed by your question. Let's get started!")

voice_recognizer = speech_recognition.Recognizer()
speaking_engine = pyttsx3.init()

def speak(text):
    speaking_engine.stop()
    speaking_engine.say(text)
    speaking_engine.runAndWait()

def ai_chat(question):

    try:
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={
                "model": "llama3.2",
                "prompt": question,
                "stream": False
            }
        )
        answer = response.json()["response"]
        print("\nAI:" + answer)
        speak(answer)
    except Exception as e:
        print("AI Error:", e)

